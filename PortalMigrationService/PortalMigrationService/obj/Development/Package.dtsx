                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    u.Id AS SourceId,
    u.UserName,
    u.Email,
	u.PasswordHash,
    CONVERT(VARCHAR(32),
        HASHBYTES('MD5',
            ISNULL(u.UserName,'') +
            ISNULL(u.Email,'') +
			ISNULL(u.PasswordHash,'') +
            ISNULL(u.Email,'') 
        ),2) AS SourceRowHash
FROM BB_Env1.dbo.aspnetusers u</property>
