      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Insert User Mapping"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{735EAF7A-C512-4DB9-85EE-235CA2DD8F9F}"
          SQLTask:SqlStatementSource="INSERT INTO UserIdMapping(SourceId, TargetId)&#xA;SELECT s.Id, u.Id&#xA;FROM StagingUsers s&#xA;JOIN auth.Users u&#xA;    ON u.Email = s.Email&#xA;LEFT JOIN UserIdMapping m&#xA;    ON m.SourceId = s.Id&#xA;WHERE m.SourceId IS NULL" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Marge Users"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{16ba3c47-7f8e-4375-b773-1a6d4b14c67c}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Marge Users"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D3F59600-7C9B-441A-A9C5-62DCBD6BBD2E}"
          SQLTask:SqlStatementSource="MERGE aspnetusers AS Target&#xA;USING stagingusers AS Source&#xA;ON Target.Id = Source.TargetId&#xA;&#xA;WHEN MATCHED THEN&#xA;    UPDATE SET&#xA;        username = Source.FirstName+' '+Source.LastName,&#xA;&#x9;&#x9;PasswordHash = Source.PasswordHash,&#xA;        Email = Source.Email&#xA;&#xA;WHEN NOT MATCHED THEN&#xA;INSERT  &#xA;(&#xA;    Id,&#xA;    AccessFailedCount,&#xA;    ConcurrencyStamp,&#xA;    Email,&#xA;    EmailConfirmed,&#xA;    LockoutEnabled,&#xA;    LockoutEnd,&#xA;    NormalizedEmail,&#xA;    NormalizedUserName,&#xA;    PasswordHash,&#xA;    PhoneNumber,&#xA;    PhoneNumberConfirmed,&#xA;    SecurityStamp,&#xA;    TwoFactorEnabled,&#xA;    UserName&#xA;)&#xA;VALUES&#xA;(&#xA;    Source.TargetId,                  -- Id (you can also pass your own)&#xA;    0,                        -- AccessFailedCount&#xA;    NEWID(),                  -- ConcurrencyStamp&#xA;    Source.Email,       -- Email&#xA;    1,                        -- EmailConfirmed&#xA;    0,                        -- LockoutEnabled&#xA;    NULL,                     -- LockoutEnd&#xA;    Source.Email,       -- NormalizedEmail&#xA;    Source.Email,               -- NormalizedUserName&#xA;    Source.PasswordHash,   -- PasswordHash&#xA;    NULL,                     -- PhoneNumber&#xA;    0,                        -- PhoneNumberConfirmed&#xA;    NEWID(),                  -- SecurityStamp&#xA;    0,                        -- TwoFactorEnabled&#xA;    Source.FirstName+' '+Source.LastName                -- UserName&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
